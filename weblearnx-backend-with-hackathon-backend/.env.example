# Server
PORT=5000
NODE_ENV=development   # change to "production" for remote deployment

# JWT Auth
JWT_SECRET=your-strong-random-secret-here

# Database — Local (XAMPP / development)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=weblearnx

